class Node:
    def __init__(self,data):
        self.data=data
        self.next=None

n1=Node(10)
n2=Node(20)
n3=Node(25)
n4=Node(30)
n1.next=n2
n2.next=n3
n3.next=n4

head=n1
def display(head):
     temp=head
     while temp is not None:
         print(temp.data,end="->")
         temp=temp.next
     print("None")
print("Original Linked List")
display(head)
print("Deletion at Middle")
temp=head
while temp.next.data!=25:
    temp=temp.next
temp.next=temp.next.next
display(head)
